/*
 * nf-lamin configuration for nf-core/scrnaseq
 *
 * This config adds the nf-lamin plugin and defines artifact tracking rules
 * for the most relevant input and output files produced by nf-core/scrnaseq
 * (STARSolo aligner).
 *
 * Usage:
 *   nextflow run nf-core/scrnaseq -r 4.1.0 -profile docker,test \
 *     -c nextflow.config \
 *     --outdir s3://your-bucket/scrnaseq/run_$(date +%Y%m%d_%H%M%S)
 */

plugins {
  id 'nf-lamin@0.6.1'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    enabled = true

    rules {
      // Track samplesheet input file(s) specified by the user.
      // NOTE: Use paths to explicitly specify the input files for this rule.
      // Since this wf processes the samplesheet inside a Groovy helper (nf-schema's
      // samplesheetToList), the samplesheet is never staged into a Nextflow process.
      samplesheet {
        include_paths = { params.input }
        kind = 'dataset'
        order = 1
      }

      // Track FASTQ input files
      fastq_reads {
        pattern = '.*\\.fastq(\\.gz)?$'
        kind = 'dataset'
        order = 2
      }

      // Track reference genome FASTA
      reference_fasta {
        pattern = '.*\\.(fasta|fa)(\\.gz)?$'
        kind = 'dataset'
        order = 3
      }

      // Track GTF annotation files
      annotation {
        pattern = '.*\\.(gtf|gff|gff3)(\\.gz)?$'
        kind = 'dataset'
        order = 4
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    enabled = true

    // Derive artifact keys by stripping the output directory from the file path.
    key = [relativize: { params.outdir }]

    // Exclude everything by default; only files matching an include rule are tracked.
    exclude_pattern = '.*'

    rules {
      // --- Enabled: Key results (tracked by default) ---

      // MultiQC report — summary of all QC metrics
      multiqc_report {
        type = 'include'
        pattern = '.*multiqc_report\\.html$'
        kind = 'report'
        order = 1
      }

      // Combined filtered count matrix (h5ad) — primary result
      combined_filtered_h5ad {
        type = 'include'
        pattern = '.*/mtx_conversions/combined_filtered_matrix\\.h5ad$'
        kind = 'dataset'
        order = 2
      }

      // Combined raw count matrix (h5ad)
      combined_raw_h5ad {
        type = 'include'
        pattern = '.*/mtx_conversions/combined_raw_matrix\\.h5ad$'
        kind = 'dataset'
        order = 3
      }

      // Per-sample filtered count matrices (h5ad)
      sample_filtered_h5ad {
        type = 'include'
        pattern = '.*/mtx_conversions/.+/.+_filtered_matrix\\.h5ad$'
        kind = 'dataset'
        order = 4
      }

      // Per-sample raw count matrices (h5ad)
      sample_raw_h5ad {
        type = 'include'
        pattern = '.*/mtx_conversions/.+/.+_raw_matrix\\.h5ad$'
        kind = 'dataset'
        order = 5
      }

      // --- Disabled: Optional outputs (enable as needed) ---

      // RDS conversion files (Seurat/SingleCellExperiment)
      rds_conversions {
        type = 'include'
        enabled = false
        pattern = '.*/mtx_conversions/.*\\.rds$'
        kind = 'dataset'
        order = 10
      }

      // BAM files (genome-aligned reads)
      bam_files {
        type = 'include'
        enabled = false
        pattern = '.*\\.bam$'
        kind = 'dataset'
        order = 11
      }

      // STARSolo filtered count matrices (mtx format)
      starsolo_filtered_mtx {
        type = 'include'
        enabled = false
        pattern = '.*/Solo\\.out/Gene/filtered/.*\\.(mtx|tsv)\\.gz$'
        kind = 'dataset'
        order = 12
      }

      // STARSolo raw count matrices (mtx format)
      starsolo_raw_mtx {
        type = 'include'
        enabled = false
        pattern = '.*/Solo\\.out/Gene/raw/.*\\.(mtx|tsv)\\.gz$'
        kind = 'dataset'
        order = 13
      }

      // STARSolo summary statistics
      starsolo_summary {
        type = 'include'
        enabled = false
        pattern = '.*/Solo\\.out/Gene/Summary\\.csv$'
        kind = 'dataset'
        order = 14
      }

      // FastQC HTML reports
      fastqc_reports {
        type = 'include'
        enabled = false
        pattern = '.*_fastqc\\.html$'
        kind = 'report'
        order = 20
      }

      // FastQC zip archives
      fastqc_zip {
        type = 'include'
        enabled = false
        pattern = '.*_fastqc\\.zip$'
        kind = 'dataset'
        order = 21
      }

      // MultiQC raw data and plots
      multiqc_data {
        type = 'include'
        enabled = false
        pattern = '.*/multiqc/(multiqc_data|multiqc_plots)/.*'
        kind = 'dataset'
        order = 22
      }

      // Pipeline execution info (reports, traces, timelines)
      pipeline_info {
        type = 'include'
        enabled = false
        pattern = '.*/pipeline_info/.*'
        kind = 'report'
        order = 30
      }
    }
  }
}
