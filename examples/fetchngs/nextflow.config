/*
 * nf-lamin configuration for nf-core/fetchngs
 *
 * Tracks accession IDs (input), downloaded FASTQs, metadata, and the merged
 * samplesheet/id_mappings files (output) as LaminDB artifacts.
 *
 * The samplesheet and id_mappings CSVs are produced by .collectFile(storeDir:)
 * rather than publishDir, so they never trigger onFilePublish and must be
 * listed explicitly via include_paths.
 */

plugins {
  id 'nf-lamin@0.6.2'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  input_artifacts {
    enabled = true
    exclude_pattern = '.*'   // exclude intermediates (e.g. id_mappings passed between processes)

    rules {
      accession_ids {
        include_paths = { params.input }
        kind  = 'dataset'
        order = 1
      }
    }
  }

  output_artifacts {
    enabled = true
    key = [relativize: params.outdir]
    exclude_pattern = '.*'   // only track files matching a rule below

    rules {
      // .collectFile() outputs — must use include_paths (no onFilePublish event)
      samplesheet {
        include_paths = { ["${params.outdir}/samplesheet/samplesheet.csv"] }
        kind  = 'dataset'
        order = 1
      }
      id_mappings {
        include_paths = { ["${params.outdir}/samplesheet/id_mappings.csv"] }
        kind  = 'dataset'
        order = 2
      }

      // Standard publishDir outputs
      metadata {
        type    = 'include'
        pattern = '.*/metadata/.*\\.runinfo_ftp\\.tsv$'
        kind    = 'dataset'
        order   = 3
      }
      fastq {
        type    = 'include'
        pattern = '.*/fastq/.*\\.fastq\\.gz$'
        kind    = 'dataset'
        order   = 4
      }
      execution_report {
        type    = 'include'
        pattern = '.*/pipeline_info/execution_report.*\\.html$'
        kind    = 'report'
        order   = 5
      }

      // Disabled — enable as needed
      execution_timeline {
        type = 'include'; enabled = false
        pattern = '.*/pipeline_info/execution_timeline.*\\.html$'
        kind = 'report'; order = 10
      }
      pipeline_dag {
        type = 'include'; enabled = false
        pattern = '.*/pipeline_info/pipeline_dag.*\\.html$'
        kind = 'report'; order = 11
      }
      execution_trace {
        type = 'include'; enabled = false
        pattern = '.*/pipeline_info/execution_trace.*\\.txt$'
        kind = 'dataset'; order = 12
      }
      software_versions {
        type = 'include'; enabled = false
        pattern = '.*/pipeline_info/.*_software_mqc_versions\\.yml$'
        kind = 'dataset'; order = 13
      }
      md5 {
        type = 'include'; enabled = false
        pattern = '.*/fastq/md5/.*\\.md5$'
        kind = 'dataset'; order = 14
      }
    }
  }
}
