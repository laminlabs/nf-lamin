/*
 * nf-lamin configuration for nf-core/fetchngs
 *
 * nf-core/fetchngs downloads FASTQ files from public repositories (SRA, ENA,
 * DDBJ, GEO) and generates a ready-to-use samplesheet for downstream nf-core
 * workflows.
 *
 * Key inputs tracked:
 *   params.input                  – CSV file of SRA/ENA/DDBJ/GEO accession IDs
 *
 * Key outputs tracked:
 *   samplesheet/samplesheet.csv   – nf-core-compatible samplesheet (dataset)
 *   samplesheet/id_mappings.csv   – accession → sample ID mapping (dataset)
 *   metadata/*.runinfo_ftp.tsv    – per-run ENA/SRA run-info metadata (dataset)
 *   fastq/*.fastq.gz              – downloaded FASTQ files (dataset)
 *   pipeline_info/execution_*.html – pipeline execution report (report)
 *
 * Note on samplesheets: samplesheet.csv and id_mappings.csv are written by
 * Nextflow's .collectFile() operator (storeDir), not by publishDir, so they
 * never appear in onFilePublish.  They must therefore be listed explicitly via
 * include_paths inside an ArtifactRule so that they are registered at the end
 * of the run.  See: workflows/sra/main.nf lines 148-155.
 *
 * Note on id_mappings as input: the MULTIQC_MAPPINGS_CONFIG process takes
 * id_mappings.csv as an input file.  Without explicit input_artifacts rules,
 * nf-lamin would fall back to tracking it as an input artifact with default
 * settings.  The rule below suppresses that by excluding everything except the
 * primary accession-ID CSV supplied via params.input.
 *
 * Usage (from the repo root):
 *   make && make install   # builds and installs the dev plugin
 *   bash examples/fetchngs/script.sh
 */

plugins {
  id 'nf-lamin@0.6.1-dev'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    enabled = true

    // Exclude everything by default; only files matching an include rule are tracked.
    // This prevents intermediate files (e.g. id_mappings.csv passed between
    // processes) from being registered as top-level input artifacts.
    exclude_pattern = '.*'

    rules {
      // Track input file(s) specified by the user.
      access_ids {
        include_paths = { params.input }
        kind = 'dataset'
        order = 1
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    enabled = true

    // Derive artifact keys by stripping the output directory prefix.
    // e.g. <outdir>/fastq/SRR123.fastq.gz → fastq/SRR123.fastq.gz
    key = [relativize: params.outdir]

    // Exclude everything by default; only files matching an include rule are tracked.
    exclude_pattern = '.*'

    rules {
      // Merged nf-core-compatible samplesheet.
      // Written via .collectFile(storeDir: ...) — not publishDir — so it never
      // appears in onFilePublish and must be listed here explicitly.
      samplesheet {
        include_paths = {
          ["${params.outdir}/samplesheet/samplesheet.csv"]
        }
        kind  = 'dataset'
        order = 1
      }

      // Accession-to-sample ID mapping.
      // Also written via .collectFile() — same reasoning as samplesheet above.
      id_mappings {
        include_paths = {
          ["${params.outdir}/samplesheet/id_mappings.csv"]
        }
        kind  = 'dataset'
        order = 2
      }

      // Per-run ENA/SRA metadata TSV files.
      metadata {
        type    = 'include'
        pattern = '.*/metadata/.*\\.runinfo_ftp\\.tsv$'
        kind    = 'dataset'
        order   = 3
      }

      // Downloaded FASTQ files (the primary output of fetchngs).
      fastq {
        type    = 'include'
        pattern = '.*/fastq/.*\\.fastq\\.gz$'
        kind    = 'dataset'
        order   = 4
      }

      // Execution report (HTML summary of the pipeline run).
      execution_report {
        type    = 'include'
        pattern = '.*/pipeline_info/execution_report.*\\.html$'
        kind    = 'report'
        order   = 5
      }

      // --- Disabled: Optional outputs (enable as needed) ---

      // Execution timeline
      execution_timeline {
        type    = 'include'
        enabled = false
        pattern = '.*/pipeline_info/execution_timeline.*\\.html$'
        kind    = 'report'
        order   = 10
      }

      // Pipeline DAG
      pipeline_dag {
        type    = 'include'
        enabled = false
        pattern = '.*/pipeline_info/pipeline_dag.*\\.html$'
        kind    = 'report'
        order   = 11
      }

      // Execution trace (plain-text process timing)
      execution_trace {
        type    = 'include'
        enabled = false
        pattern = '.*/pipeline_info/execution_trace.*\\.txt$'
        kind    = 'dataset'
        order   = 12
      }

      // Software versions YAML
      software_versions {
        type    = 'include'
        enabled = false
        pattern = '.*/pipeline_info/.*_software_mqc_versions\\.yml$'
        kind    = 'dataset'
        order   = 13
      }

      // MD5 checksums for downloaded FASTQs
      md5 {
        type    = 'include'
        enabled = false
        pattern = '.*/fastq/md5/.*\\.md5$'
        kind    = 'dataset'
        order   = 14
      }
    }
  }
}
