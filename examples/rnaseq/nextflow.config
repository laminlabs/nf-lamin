/*
 * nf-lamin configuration for nf-core/rnaseq
 *
 * This config adds the nf-lamin plugin and defines artifact tracking rules
 * for the most relevant input and output files produced by nf-core/rnaseq.
 *
 * Usage:
 *   nextflow run nf-core/rnaseq -r 3.23.0 -profile docker,test \
 *     -c nextflow.config \
 *     --outdir s3://your-bucket/rnaseq/run_$(date +%Y%m%d_%H%M%S)
 */

plugins {
  id 'nf-lamin@0.5.2'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    enabled = true

    rules {
      // Track samplesheet input file(s) specified by the user.
      // NOTE: Use paths to explicitly specify the input files for this rule.
      // Since this wf processes the samplesheet inside a Groovy helper (nf-schema's
      // samplesheetToList), the samplesheet is never staged into a Nextflow process.
      samplesheet {
        paths = { [params.input] } // Use a closure to access workflow params
        kind = 'dataset'
        order = 1
      }

      // Track FASTQ input files
      fastq_reads {
        pattern = '.*\\.fastq(\\.gz)?$'
        kind = 'dataset'
        order = 2
      }

      // Track reference genome FASTA
      reference_fasta {
        pattern = '.*\\.(fasta|fa)(\\.gz)?$'
        kind = 'dataset'
        order = 3
      }

      // Track GTF/GFF annotation files
      annotation {
        pattern = '.*\\.(gtf|gff|gff3)(\\.gz)?$'
        kind = 'dataset'
        order = 4
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    enabled = true

    // Derive artifact keys by stripping the output directory from the file path.
    key = [relativize: params.outdir]

    // Exclude logs, version files, and pipeline info by default
    exclude_pattern = '.*\\.(log|command\\..*)$'

    rules {
      // --- Key results ---

      // MultiQC report — summary of all QC metrics
      multiqc_report {
        pattern = '.*multiqc_report\\.html$'
        kind = 'report'
        order = 1
      }

      // Gene count matrices (Salmon/RSEM merged counts)
      gene_counts {
        pattern = '.*\\.(gene_counts|gene_tpm|gene_counts_length_scaled|transcript_counts)\\.tsv$'
        kind = 'dataset'
        order = 2
      }

      // Salmon quantification files
      salmon_quant {
        pattern = '.*/salmon\\.merged\\..*\\.(tsv|sf)$'
        kind = 'dataset'
        order = 3
      }

      // SummarizedExperiment RDS files
      summarized_experiment {
        pattern = '.*\\.rds$'
        kind = 'dataset'
        order = 4
      }

      // --- Alignment files ---

      // BAM files (genome-aligned reads)
      bam_files {
        pattern = '.*\\.bam$'
        kind = 'dataset'
        order = 10
      }

      // BAM index files
      bam_index {
        pattern = '.*\\.bam\\.bai$'
        kind = 'dataset'
        order = 11
      }

      // Bigwig coverage tracks
      bigwig_files {
        pattern = '.*\\.bigWig$'
        kind = 'dataset'
        order = 12
      }

      // --- QC reports ---

      // FastQC reports
      fastqc_reports {
        pattern = '.*_fastqc\\.html$'
        kind = 'report'
        order = 20
      }

      // --- Exclude intermediate/noisy files ---

      // Exclude versions.yml files
      exclude_versions {
        type = 'exclude'
        pattern = '.*versions\\.yml$'
        order = 90
      }

      // Exclude pipeline execution info (reports, traces, timelines)
      exclude_pipeline_info {
        type = 'exclude'
        pattern = '.*/pipeline_info/.*'
        order = 91
      }

      // Exclude FastQC zip files (HTML is sufficient)
      exclude_fastqc_zip {
        type = 'exclude'
        pattern = '.*_fastqc\\.zip$'
        order = 92
      }

      // Exclude trimming logs
      exclude_trim_logs {
        type = 'exclude'
        pattern = '.*trimming_report\\.txt$'
        order = 93
      }

      // Exclude STAR log files
      exclude_star_logs {
        type = 'exclude'
        pattern = '.*Log\\.(final\\.out|out|progress\\.out)$'
        order = 94
      }
    }
  }
}
