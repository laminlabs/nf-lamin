/*
 * nf-lamin configuration for nf-core/rnaseq
 *
 * This config adds the nf-lamin plugin and defines artifact tracking rules
 * for the most relevant input and output files produced by nf-core/rnaseq.
 *
 * Usage:
 *   nextflow run nf-core/rnaseq -r 3.23.0 -profile docker,test \
 *     -c nextflow.config \
 *     --outdir s3://your-bucket/rnaseq/run_$(date +%Y%m%d_%H%M%S)
 */

plugins {
  id 'nf-lamin@0.6.2'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    enabled = true

    rules {
      // Track samplesheet input file(s) specified by the user.
      // NOTE: Use paths to explicitly specify the input files for this rule.
      // Since this wf processes the samplesheet inside a Groovy helper (nf-schema's
      // samplesheetToList), the samplesheet is never staged into a Nextflow process.
      samplesheet {
        include_paths = { params.input } // Use a closure to access workflow params
        kind = 'dataset'
        order = 1
      }

      // Track FASTQ input files
      fastq_reads {
        pattern = '.*\\.fastq(\\.gz)?$'
        kind = 'dataset'
        order = 2
      }

      // Track reference genome FASTA
      reference_fasta {
        pattern = '.*\\.(fasta|fa)(\\.gz)?$'
        kind = 'dataset'
        order = 3
      }

      // Track GTF/GFF annotation files
      annotation {
        pattern = '.*\\.(gtf|gff|gff3)(\\.gz)?$'
        kind = 'dataset'
        order = 4
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    enabled = true

    // Derive artifact keys by stripping the output directory from the file path.
    key = [relativize: params.outdir]

    // Exclude everything by default; only files matching an include rule are tracked.
    exclude_pattern = '.*'

    rules {
      // --- Enabled: Key results (tracked by default) ---

      // MultiQC report — summary of all QC metrics
      multiqc_report {
        type = 'include'
        pattern = '.*multiqc_report\\.html$'
        kind = 'report'
        order = 1
      }

      // Merged gene count matrices (counts, TPM, lengths, scaled)
      gene_counts {
        type = 'include'
        pattern = '.*salmon\\.merged\\.gene_(counts|tpm|counts_length_scaled|counts_scaled|lengths)\\.tsv$'
        kind = 'dataset'
        order = 2
      }

      // Merged transcript quantification files (counts, TPM, lengths)
      transcript_counts {
        type = 'include'
        pattern = '.*salmon\\.merged\\.transcript_(counts|tpm|lengths)\\.tsv$'
        kind = 'dataset'
        order = 3
      }

      // SummarizedExperiment RDS files (gene and transcript level)
      summarized_experiment {
        type = 'include'
        pattern = '.*\\.SummarizedExperiment\\.rds$'
        kind = 'dataset'
        order = 4
      }

      // Transcript-to-gene mapping
      tx2gene {
        type = 'include'
        pattern = '.*salmon\\.merged\\.tx2gene\\.tsv$'
        kind = 'dataset'
        order = 5
      }

      // --- Disabled: Optional outputs (enable as needed) ---

      // Per-sample Salmon quantification files
      salmon_quant {
        type = 'include'
        enabled = false
        pattern = '.*/salmon/.+/quant(\\.(genes))?\\.sf$'
        kind = 'dataset'
        order = 10
      }

      // BAM files (genome-aligned reads)
      bam_files {
        type = 'include'
        enabled = false
        pattern = '.*\\.bam$'
        kind = 'dataset'
        order = 11
      }

      // BAM index files
      bam_index {
        type = 'include'
        enabled = false
        pattern = '.*\\.bam\\.bai$'
        kind = 'dataset'
        order = 12
      }

      // Bigwig coverage tracks
      bigwig_files {
        type = 'include'
        enabled = false
        pattern = '.*\\.bigWig$'
        kind = 'dataset'
        order = 13
      }

      // DESeq2 QC outputs (PCA, sample distances, plots)
      deseq2_qc {
        type = 'include'
        enabled = false
        pattern = '.*/deseq2_qc/.*'
        kind = 'dataset'
        order = 14
      }

      // featureCounts output tables
      featurecounts {
        type = 'include'
        enabled = false
        pattern = '.*/featurecounts/.*\\.featureCounts\\.tsv$'
        kind = 'dataset'
        order = 15
      }

      // FastQC HTML reports
      fastqc_reports {
        type = 'include'
        enabled = false
        pattern = '.*_fastqc\\.html$'
        kind = 'report'
        order = 20
      }

      // FastQC zip archives
      fastqc_zip {
        type = 'include'
        enabled = false
        pattern = '.*_fastqc\\.zip$'
        kind = 'dataset'
        order = 21
      }

      // MultiQC raw data and plots
      multiqc_data {
        type = 'include'
        enabled = false
        pattern = '.*/multiqc/.*/multiqc_report_data/.*'
        kind = 'dataset'
        order = 22
      }

      // Trimming reports
      trimming_reports {
        type = 'include'
        enabled = false
        pattern = '.*trimming_report\\.txt$'
        kind = 'report'
        order = 23
      }

      // Pipeline execution info (reports, traces, timelines)
      pipeline_info {
        type = 'include'
        enabled = false
        pattern = '.*/pipeline_info/.*'
        kind = 'report'
        order = 30
      }
    }
  }
}
