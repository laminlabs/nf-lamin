/*
 * nf-lamin configuration for bigbio/quantms
 *
 * This config adds the nf-lamin plugin and defines artifact tracking rules
 * for the most relevant output files produced by bigbio/quantms (DDA-LFQ mode).
 *
 * Usage:
 *   nextflow run bigbio/quantms -r 1.7.0 -profile docker,test_lfq \
 *     -c examples/quantms/nextflow.config \
 *     --outdir output/quantms/
 */

plugins {
  id 'nf-lamin@0.7.0'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    rules {
      // Track SDRF experimental design files
      sdrf {
        pattern = '.*\\.sdrf\\.tsv$'
        kind = 'dataset'
        order = 1
      }

      // Track protein database FASTA
      fasta {
        pattern = '.*\\.(fasta|fa)(\\.gz)?$'
        kind = 'dataset'
        order = 2
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    // Derive artifact keys by stripping the output directory from the file path.
    key {
      relativize = { params.outdir }
    }

    // Exclude everything by default; only files matching an include rule are tracked.
    exclude_pattern = '.*'

    rules {
      // --- Enabled: Key results (tracked by default) ---

      // mzTab — main identification and quantification result (submission-ready)
      mztab {
        type = 'include'
        pattern = '.*\\.mzTab$'
        kind = 'dataset'
        order = 1
      }

      // MSstats input table
      msstats_in {
        type = 'include'
        pattern = '.*msstats_in\\.csv$'
        kind = 'dataset'
        order = 2
      }

      // MSstats comparison results
      msstats_comparisons {
        type = 'include'
        pattern = '.*msstats_in_comparisons\\.csv$'
        kind = 'dataset'
        order = 3
      }

      // pMultiQC report — proteomics QC summary
      multiqc_report {
        type = 'include'
        pattern = '.*/pmultiqc/multiqc_report\\.html$'
        kind = 'report'
        order = 4
      }

      // Triqler input table
      triqler {
        type = 'include'
        pattern = '.*triqler_in\\.tsv$'
        kind = 'dataset'
        order = 5
      }

      // --- Disabled: Optional outputs (enable as needed) ---

      // ConsensusXML — intermediate OpenMS quantification format
      consensusxml {
        type = 'include'
        enabled = false
        pattern = '.*\\.consensusXML$'
        kind = 'dataset'
        order = 10
      }

      // Spectra statistics (parquet files with MS1/MS2 info)
      spectra_statistics {
        type = 'include'
        enabled = false
        pattern = '.*/mzml_statistics/.*\\.parquet$'
        kind = 'dataset'
        order = 11
      }

      // pMultiQC raw data and plots
      multiqc_data {
        type = 'include'
        enabled = false
        pattern = '.*/pmultiqc/(multiqc_data|multiqc_plots)/.*'
        kind = 'dataset'
        order = 20
      }

      // Pipeline execution info (reports, traces, timelines)
      pipeline_info {
        type = 'include'
        enabled = false
        pattern = '.*/pipeline_info/.*'
        kind = 'report'
        order = 30
      }
    }
  }
}
