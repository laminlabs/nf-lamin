/*
 * nf-lamin configuration for bigbio/quantms
 *
 * This config adds the nf-lamin plugin and defines artifact tracking rules
 * for the most relevant output files produced by bigbio/quantms (DDA-LFQ mode).
 *
 * Usage:
 *   nextflow run bigbio/quantms -r 1.7.0 -profile docker,test_lfq \
 *     -c examples/quantms/nextflow.config \
 *     --outdir output/quantms/
 */

plugins {
  id 'nf-lamin@0.6.0'
}

lamin {
  instance = "laminlabs/lamindata"
  api_key = secrets.LAMIN_API_KEY

  // Input artifact tracking
  input_artifacts {
    enabled = true

    rules {
      // Track SDRF experimental design files
      sdrf {
        pattern = '.*\\.sdrf\\.tsv$'
        kind = 'dataset'
        order = 1
      }

      // Track protein database FASTA
      fasta {
        pattern = '.*\\.(fasta|fa)(\\.gz)?$'
        kind = 'dataset'
        order = 2
      }
    }
  }

  // Output artifact tracking
  output_artifacts {
    enabled = true

    // Derive artifact keys by stripping the output directory from the file path.
    key = [relativize: params.outdir]

    rules {
      // --- Key results ---

      // mzTab — main identification and quantification result (submission-ready)
      mztab {
        pattern = '.*\\.mzTab$'
        kind = 'dataset'
        order = 1
      }

      // MSstats input table
      msstats_in {
        pattern = '.*msstats_in\\.csv$'
        kind = 'dataset'
        order = 2
      }

      // MSstats-processed results
      msstats_results {
        pattern = '.*/msstats/.*\\.(csv|tsv)$'
        kind = 'dataset'
        order = 3
      }

      // pMultiQC report — proteomics QC summary
      multiqc_report {
        pattern = '.*/pmultiqc/multiqc_report\\.html$'
        kind = 'report'
        order = 4
      }

      // Triqler output
      triqler {
        pattern = '.*triqler_in\\.tsv$'
        kind = 'dataset'
        order = 5
      }

      // --- Exclude intermediate/noisy files ---

      // Exclude pipeline execution info
      exclude_pipeline_info {
        type = 'exclude'
        pattern = '.*/pipeline_info/.*'
        order = 90
      }

      // Exclude SDRF and config files copied to output
      exclude_sdrf {
        type = 'exclude'
        pattern = '.*/sdrf/.*'
        order = 91
      }

      // Exclude pMultiQC raw data and plots (HTML report is sufficient)
      exclude_multiqc_data {
        type = 'exclude'
        pattern = '.*/pmultiqc/(multiqc_data|multiqc_plots)/.*'
        order = 92
      }

      // Exclude versions.yml files
      exclude_versions {
        type = 'exclude'
        pattern = '.*versions\\.yml$'
        order = 93
      }

      // Exclude large intermediate OpenMS formats
      exclude_consensusxml {
        type = 'exclude'
        pattern = '.*\\.consensusXML$'
        order = 94
      }

      // Exclude idXML intermediate files
      exclude_idxml {
        type = 'exclude'
        pattern = '.*\\.idXML$'
        order = 95
      }

      // Exclude log files produced by MSstats and spectrum statistics steps
      exclude_logs {
        type = 'exclude'
        pattern = '.*\\.log$'
        order = 96
      }
    }
  }
}
